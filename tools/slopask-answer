#!/usr/bin/env python3
"""slopask-answer — generate and upload slopcast answer clips for slopask questions.

Usage:
    slopask-answer generate <qid> [--course-dir DIR] [--workdir DIR]
    slopask-answer upload <qid> --workdir DIR
"""
import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

import requests
import yaml

SCRIPT_DIR = Path(__file__).resolve().parent
REPO_DIR = SCRIPT_DIR.parent
SLOPCAST_DIR = Path(os.environ.get("SLOPCAST_DIR", Path.home() / "code" / "sloppy" / "slopcast"))
TTS_PYTHON = os.environ.get("TTS_PYTHON", str(Path.home() / "code" / "sloppy" / "slopshell" / "tools" / "qwen3-tts" / ".venv" / "bin" / "python"))
TEMPLATE_TEX = SCRIPT_DIR / "answer_template.tex"
DEFAULT_API_URL = "https://ask.sloppy.at"
STT_URL = os.environ.get("SLOPASK_STT_URL", "http://127.0.0.1:8427")


def load_dotenv_file(path):
    if not Path(path).exists():
        return
    for line in Path(path).read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        os.environ.setdefault(k.strip(), v.strip())


def load_dotenv(course_dir="."):
    load_dotenv_file(Path(course_dir) / "slopask" / ".env")
    load_dotenv_file(REPO_DIR / ".env")


def load_course_config(course_dir):
    p = Path(course_dir) / "course.yaml"
    if p.exists():
        with open(p) as f:
            return yaml.safe_load(f)
    return {}


def claude_cli(prompt, files=None):
    """Run claude CLI and return stdout text. No API key needed."""
    cmd = ["claude", "-p", prompt, "--output-format", "text"]
    if files:
        cmd.extend(str(f) for f in files)
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
    if result.returncode != 0:
        print(f"claude CLI failed (exit {result.returncode}):", file=sys.stderr)
        print(result.stderr[:2000], file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip()


def fetch_question(api_url, token, qid):
    r = requests.get(f"{api_url}/api/v0/rooms/{token}/questions/{qid}")
    r.raise_for_status()
    return r.json()


def download_media(api_url, media_list, dest_dir):
    dest_dir = Path(dest_dir)
    dest_dir.mkdir(parents=True, exist_ok=True)
    paths = []
    for m in (media_list or []):
        url = api_url + m["url"]
        local = dest_dir / m["filename"]
        resp = requests.get(url)
        resp.raise_for_status()
        local.write_bytes(resp.content)
        paths.append({"path": str(local), "kind": m["kind"],
                       "mime_type": m["mime_type"], "filename": m["filename"]})
    return paths


def extract_audio(video_path, out_wav):
    """Extract audio track from video file via ffmpeg."""
    subprocess.run(
        ["ffmpeg", "-y", "-i", str(video_path), "-vn", "-acodec", "pcm_s16le",
         "-ar", "16000", "-ac", "1", str(out_wav)],
        capture_output=True, check=True,
    )
    return out_wav


def transcribe_audio(audio_path):
    """Transcribe audio via voxtype STT (OpenAI-compatible API on port 8427)."""
    with open(audio_path, "rb") as f:
        resp = requests.post(
            f"{STT_URL}/v1/audio/transcriptions",
            files={"file": (Path(audio_path).name, f)},
            data={"model": "whisper", "language": "de"},
            timeout=120,
        )
    resp.raise_for_status()
    return resp.json().get("text", "").strip()


def transcribe_question(question, media_paths, course_config):
    """Produce a markdown transcription of the question using STT + claude CLI."""
    body = question.get("body", "").strip()
    if not media_paths and body:
        return body

    parts = []
    if body:
        parts.append(body)

    image_files = []
    for m in media_paths:
        kind = m["kind"]
        if kind == "image":
            image_files.append(m["path"])
        elif kind == "audio":
            print(f"  transcribing audio: {m['filename']}...")
            text = transcribe_audio(m["path"])
            if text:
                parts.append(f"[Audio transcript]: {text}")
        elif kind == "video":
            print(f"  extracting audio from video: {m['filename']}...")
            wav_path = Path(m["path"]).with_suffix(".wav")
            extract_audio(m["path"], wav_path)
            print(f"  transcribing video audio...")
            text = transcribe_audio(str(wav_path))
            if text:
                parts.append(f"[Video transcript]: {text}")

    if image_files:
        prompt = "\n\n".join(parts) if parts else ""
        prompt += "\n\nDescribe the attached image(s) concisely and combine with the text above into clean markdown. " \
                  "Include formulas as LaTeX. Keep the original language. Output ONLY the markdown."
        return claude_cli(prompt, files=image_files)

    if parts:
        # If we only have text+transcripts, combine into markdown via claude CLI.
        combined = "\n\n".join(parts)
        prompt = f"Clean up and combine the following into a single markdown question. " \
                 f"Include formulas as LaTeX ($...$). Keep the original language. " \
                 f"Output ONLY the markdown, no explanation.\n\n{combined}"
        return claude_cli(prompt)

    return body


def generate_answer_content(question_md, course_config):
    """Use claude CLI to generate answer text + Beamer slide LaTeX + speaker notes."""
    course_name = course_config.get("course_name", "")
    language = course_config.get("language", "de")
    lang_name = "German" if language == "de" else "English"

    prompt = f"""You are answering a student question for the course "{course_name}".

Question:
{question_md}

Generate a structured answer. Output valid JSON with these fields:
- "answer_text": A brief, complete markdown answer (2-5 sentences). Use LaTeX for formulas.
- "slide_latex": Beamer LaTeX for 1-3 frames. Start with the question (paraphrased), then the answer with formulas/illustrations. Use \\pause between content blocks. Use \\autonote{{[tag] text}} for speaker notes (tags: trivial, simple, moderate, complex). Notes must be TTS-ready (proper {lang_name} punctuation, formulas spoken as words, UTF-8 umlauts).
- "livecode": null, or a Python LiveDemo script (using the LiveDemo class from slopcast) if a code example helps. Only if the question is about programming.

Rules:
- Answer in {lang_name} (matching the question language).
- Be concise but complete.
- The slide should work as a standalone mini-lecture: question, explanation, conclusion.
- Speaker notes are for TTS narration — write complete, natural sentences.
- Do NOT use \\begin{{frame}} with fragile option unless using lstlisting.
- Each frame needs a short title.

Output ONLY the JSON object, no markdown fences, no explanation."""

    text = claude_cli(prompt)
    # Strip markdown fences if present.
    if "```" in text:
        # Find the JSON between fences or after the first fence.
        lines = text.split("\n")
        inside = False
        json_lines = []
        for line in lines:
            if line.strip().startswith("```"):
                if inside:
                    break
                inside = True
                continue
            if inside:
                json_lines.append(line)
        if json_lines:
            text = "\n".join(json_lines)
    # Find the JSON object in the text.
    start = text.find("{")
    end = text.rfind("}") + 1
    if start >= 0 and end > start:
        text = text[start:end]
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        # Retry: ask claude to fix the JSON.
        fix_prompt = f"Fix this broken JSON so it parses correctly. Output ONLY the valid JSON, nothing else:\n\n{text}"
        fixed = claude_cli(fix_prompt)
        start = fixed.find("{")
        end = fixed.rfind("}") + 1
        if start >= 0 and end > start:
            fixed = fixed[start:end]
        return json.loads(fixed)


def build_beamer_pdf(slide_latex, workdir):
    template = TEMPLATE_TEX.read_text()
    tex = template.replace("%%SLIDES%%", slide_latex)
    tex_path = workdir / "slide.tex"
    tex_path.write_text(tex)
    result = subprocess.run(
        ["latexmk", "-pdf", "-interaction=nonstopmode", "-halt-on-error", "slide.tex"],
        cwd=workdir, capture_output=True, text=True,
    )
    pdf_path = workdir / "slide.pdf"
    if not pdf_path.exists():
        print("LaTeX compilation failed:", file=sys.stderr)
        print(result.stdout[-2000:] if len(result.stdout) > 2000 else result.stdout, file=sys.stderr)
        print(result.stderr[-1000:] if len(result.stderr) > 1000 else result.stderr, file=sys.stderr)
        sys.exit(1)
    return pdf_path


def write_segments_json(workdir):
    """Extract segments from the Beamer PDF using slopcast tools."""
    pdf_path = workdir / "slide.pdf"
    segments_path = workdir / "segments.json"
    extract_script = SLOPCAST_DIR / "tools" / "extract_pdfpc_notes.py"
    result = subprocess.run(
        [sys.executable, str(extract_script), str(pdf_path), "-o", str(segments_path)],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print("extract_pdfpc_notes failed:", file=sys.stderr)
        print(result.stderr, file=sys.stderr)
        sys.exit(1)
    return segments_path


def generate_slopcast_clip(workdir, voice_wav):
    """Run TTS + render to produce answer.mp4."""
    segments_path = workdir / "segments.json"
    audio_dir = workdir / "audio"
    audio_dir.mkdir(exist_ok=True)
    pdf_path = workdir / "slide.pdf"
    output_mp4 = workdir / "answer.mp4"

    # 1. Generate audio via Qwen3-TTS (uses slopcast venv).
    gen_audio = SLOPCAST_DIR / "tools" / "generate_audio_qwen3tts.py"
    print("  TTS audio generation...")
    result = subprocess.run(
        [TTS_PYTHON, str(gen_audio), str(segments_path),
         "--ref", str(voice_wav), "-o", str(audio_dir)],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print("generate_audio failed:", file=sys.stderr)
        print(result.stderr[-2000:], file=sys.stderr)
        sys.exit(1)

    # 2. Try slopcast render pipeline first.
    clips_dir = workdir / "clips"
    clips_dir.mkdir(exist_ok=True)
    render = SLOPCAST_DIR / "tools" / "render_narrated_slides.py"
    print("  rendering slides...")
    result = subprocess.run(
        [sys.executable, str(render), str(pdf_path), str(audio_dir),
         "--segments", str(segments_path), "-o", str(clips_dir)],
        capture_output=True, text=True,
    )
    if result.returncode == 0:
        clips_json = clips_dir / "clips.json"
        merge = SLOPCAST_DIR / "tools" / "merge_clips.py"
        result = subprocess.run(
            [sys.executable, str(merge), str(clips_json), "-o", str(output_mp4)],
            capture_output=True, text=True,
        )
        if result.returncode == 0:
            return output_mp4

    # 3. Fallback: simple PDF-to-video with full_lecture.wav audio.
    print("  slopcast render failed, using direct ffmpeg fallback...")
    full_wav = audio_dir / "full_lecture.wav"
    if not full_wav.exists():
        print("no full_lecture.wav found", file=sys.stderr)
        sys.exit(1)

    pngs_dir = workdir / "pngs"
    pngs_dir.mkdir(exist_ok=True)
    subprocess.run(["pdftoppm", "-png", "-r", "200", str(pdf_path), str(pngs_dir / "page")],
                   capture_output=True, check=True)

    durations = json.load(open(audio_dir / "durations.json"))
    segments = json.load(open(segments_path))
    concat_lines = []
    last_png = None
    for i, seg in enumerate(segments):
        # pdftoppm zero-pads page numbers (e.g. page-01.png for <100 pages).
        page = seg["page"]
        for fmt in [f"page-{page:02d}.png", f"page-{page}.png", f"page-{page:03d}.png"]:
            candidate = pngs_dir / fmt
            if candidate.exists():
                break
        png = str(candidate.resolve())
        dur = durations.get(f"segment_{i+1:03d}.wav", 4.0)
        concat_lines.append(f"file '{png}'")
        concat_lines.append(f"duration {dur}")
        last_png = png
    concat_lines.append(f"file '{last_png}'")  # last_png already absolute

    concat_file = workdir / "slides_concat.txt"
    concat_file.write_text("\n".join(concat_lines))

    subprocess.run([
        "ffmpeg", "-y", "-f", "concat", "-safe", "0", "-i", str(concat_file.resolve()),
        "-i", str(full_wav.resolve()),
        "-vf", "scale=1920:1080:force_original_aspect_ratio=decrease,pad=1920:1080:(ow-iw)/2:(oh-ih)/2:white",
        "-c:v", "libx264", "-preset", "fast", "-crf", "23",
        "-c:a", "aac", "-b:a", "128k", "-shortest", "-r", "30",
        str(output_mp4.resolve()),
    ], capture_output=True, text=True, check=False)
    if result.returncode != 0:
        print(f"ffmpeg fallback failed (exit {result.returncode}):", file=sys.stderr)
        print(result.stderr[-2000:], file=sys.stderr)
        sys.exit(1)

    return output_mp4


def update_question_body(api_url, token, qid, body):
    r = requests.put(
        f"{api_url}/admin/{token}/questions/{qid}",
        json={"body": body},
    )
    r.raise_for_status()
    return r.json()


def upload_answer(api_url, token, qid, body_text, video_path):
    files = {}
    if video_path and Path(video_path).exists():
        files["media"] = ("answer.mp4", open(video_path, "rb"), "video/mp4")
    data = {"body": body_text}
    r = requests.post(
        f"{api_url}/admin/{token}/questions/{qid}/answer",
        data=data, files=files,
    )
    r.raise_for_status()
    return r.json()


def cmd_generate(args):
    config = load_course_config(args.course_dir)

    # Resolve voice reference.
    voice_ref = None
    vr = config.get("voice_reference", {})
    if vr.get("wav"):
        voice_ref = Path(args.course_dir) / vr["wav"]
        if not voice_ref.exists():
            print(f"Voice reference not found: {voice_ref}", file=sys.stderr)
            sys.exit(1)

    # Workdir.
    workdir = Path(args.workdir) if args.workdir else Path(args.course_dir) / "slopask" / f"q{args.qid}"
    workdir.mkdir(parents=True, exist_ok=True)
    print(f"workdir: {workdir}")

    # 1. Fetch question.
    print("fetching question...")
    question = fetch_question(args.api_url, args.token, args.qid)
    (workdir / "question.json").write_text(json.dumps(question, indent=2))

    # 2. Download media.
    media_paths = []
    if question.get("media"):
        print(f"downloading {len(question['media'])} media files...")
        media_paths = download_media(args.api_url, question["media"], workdir / "question_media")

    # 3. Transcribe to markdown (if multimodal).
    question_md = question.get("body", "").strip()
    if media_paths or not question_md:
        print("transcribing question to markdown (claude CLI)...")
        question_md = transcribe_question(question, media_paths, config)
        (workdir / "question_md.txt").write_text(question_md)
        print("updating question body on server...")
        update_question_body(args.api_url, args.token, args.qid, question_md)

    # 4. Generate answer content.
    print("generating answer content (claude CLI)...")
    answer = generate_answer_content(question_md, config)
    (workdir / "answer_content.json").write_text(json.dumps(answer, indent=2))
    (workdir / "answer_text.md").write_text(answer["answer_text"])

    # 5. Build Beamer PDF.
    print("building Beamer PDF...")
    build_beamer_pdf(answer["slide_latex"], workdir)

    # 6. Write livecode if present.
    if answer.get("livecode"):
        livecode_dir = workdir / "livecode"
        livecode_dir.mkdir(exist_ok=True)
        (livecode_dir / "demo.py").write_text(answer["livecode"])

    # 7. Extract segments from PDF.
    print("extracting segments...")
    write_segments_json(workdir)

    # 8. Generate slopcast clip (if voice reference available).
    if voice_ref:
        print("generating slopcast clip...")
        mp4 = generate_slopcast_clip(workdir, voice_ref)
        print(f"video: {mp4}")
    else:
        print("no voice reference configured — skipping video generation")

    print()
    print(f"=== generated answer for question #{args.qid} ===")
    print(f"text:  {workdir / 'answer_text.md'}")
    print(f"slide: {workdir / 'slide.pdf'}")
    if voice_ref:
        print(f"video: {workdir / 'answer.mp4'}")
    print()
    print("review, then run:")
    print(f"  slopask-answer upload {args.qid} --workdir {workdir}")


def cmd_upload(args):
    workdir = Path(args.workdir) if args.workdir else None
    if not workdir or not workdir.exists():
        print("workdir not found — run generate first", file=sys.stderr)
        sys.exit(1)

    answer_text = (workdir / "answer_text.md").read_text()
    video_path = workdir / "answer.mp4"
    if not video_path.exists():
        video_path = None

    print(f"uploading answer for question #{args.qid}...")
    result = upload_answer(args.api_url, args.token, args.qid, answer_text, video_path)
    print(f"answer v{result.get('version', '?')} uploaded")
    print(f"view: {args.api_url}/admin/{args.token}")


def main():
    parser = argparse.ArgumentParser(description="slopask answer pipeline")
    parser.add_argument("--api-url", default=None)
    sub = parser.add_subparsers(dest="command", required=True)

    gen = sub.add_parser("generate", help="Generate answer for a question")
    gen.add_argument("qid", type=int, help="Question ID")
    gen.add_argument("--token", default="", help="Room admin token (default: from slopask/.env)")
    gen.add_argument("--course-dir", default=".", help="Course directory with course.yaml")
    gen.add_argument("--workdir", help="Working directory (default: slopask/q<qid>/)")

    up = sub.add_parser("upload", help="Upload generated answer")
    up.add_argument("qid", type=int, help="Question ID")
    up.add_argument("--token", default="", help="Room admin token (default: from slopask/.env)")
    up.add_argument("--workdir", required=True, help="Working directory from generate step")

    # Pre-scan for --course-dir to load .env before argparse evaluates defaults.
    course_dir = "."
    for i, a in enumerate(sys.argv):
        if a == "--course-dir" and i + 1 < len(sys.argv):
            course_dir = sys.argv[i + 1]
    load_dotenv(course_dir)

    args = parser.parse_args()
    if not args.token:
        args.token = os.environ.get("SLOPASK_TOKEN", "")
    if not args.token:
        parser.error("no admin token: use --token or put SLOPASK_TOKEN in slopask/.env")
    if not args.api_url:
        args.api_url = os.environ.get("SLOPASK_API_URL", DEFAULT_API_URL)
    if args.command == "generate":
        cmd_generate(args)
    elif args.command == "upload":
        cmd_upload(args)


if __name__ == "__main__":
    main()
